---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import SmoothScroll from "@components/SmoothScroll.astro";
import Grain from "@components/Grain.astro";
import Reveal from "@components/Reveal.astro";
import SectionHeading from "@components/SectionHeading.astro";

const img = (seed: string, w = 1600, h = 2000) =>
  `https://picsum.photos/seed/${seed}/${w}/${h}`;

// Real photography placeholders. Replace with Mazi's own graded images.
// Aspect ratios vary to keep the grid editorial, not uniform.
const shots = [
  { seed: "mazi-g1-counter", alt: "The espresso machine and a row of hanging cups.", ratio: "4 / 5", span: "tall" },
  { seed: "mazi-g2-window", alt: "Afternoon light through the café window onto an empty chair.", ratio: "3 / 2", span: "wide" },
  { seed: "mazi-g3-hands", alt: "Two hands around a warm cup on a wooden table.", ratio: "1 / 1", span: "sq" },
  { seed: "mazi-g4-roaster", alt: "Beans tumbling in a small roaster.", ratio: "3 / 2", span: "wide" },
  { seed: "mazi-g5-vinyl", alt: "A vinyl record spinning on the café turntable.", ratio: "4 / 5", span: "tall" },
  { seed: "mazi-g6-pastry", alt: "Fresh pastry on a wire rack behind the counter.", ratio: "1 / 1", span: "sq" },
  { seed: "mazi-g7-night", alt: "The room at night, lamps low, a few regulars talking.", ratio: "3 / 2", span: "wide" },
  { seed: "mazi-g8-pour", alt: "A slow pour catching steam above the cup.", ratio: "4 / 5", span: "tall" },
];
---

<BaseLayout
  title="Gallery"
  description="A look inside Mazi Specialty Coffee: the counter, the long table, the records, and the room at every hour."
  path="/gallery"
  image="/og-gallery.jpg"
>
  <SmoothScroll />
  <Grain />
  <Nav />

  <main>
    <section class="gallery-hero">
      <div class="gallery-hero__inner reading-column">
        <SectionHeading
          eyebrow="Gallery"
          title="The room, at every hour"
          body="Photographs from a normal day at Mazi. The light changes, the faces change, the warmth does not."
        />
      </div>
    </section>

    <section class="gallery">
      <div class="gallery__grid reading-column">
        {
          shots.map((s) => (
            <Reveal class:list={["gallery__cell", `gallery__cell--${s.span}`]} data-stagger>
              <img
                src={img(s.seed, 1200, 1500)}
                alt={s.alt}
                loading="lazy"
                decoding="async"
                style={`aspect-ratio: ${s.ratio}`}
              />
            </Reveal>
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .gallery-hero {
    padding-block: clamp(7rem, 18vh, 11rem) clamp(2rem, 6vw, 4rem);
  }
  .gallery {
    padding-bottom: clamp(4rem, 12vw, 8rem);
  }
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .gallery__cell {
    overflow: hidden;
    border-radius: var(--radius-xs);
    background: var(--color-canvas-night-soft);
  }
  .gallery__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out-cinematic);
  }
  @media (hover: hover) and (pointer: fine) {
    .gallery__cell:hover img {
      transform: scale(1.04);
    }
  }
  @media (min-width: 640px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .gallery__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-flow: dense;
    }
    .gallery__cell--wide {
      grid-column: span 2;
    }
    .gallery__cell--tall {
      grid-row: span 2;
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce && window.maziStagger) window.maziStagger("[data-stagger]");
</script>