---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import SmoothScroll from "@components/SmoothScroll.astro";
import Grain from "@components/Grain.astro";
import PhotoBand from "@components/PhotoBand.astro";
import Reveal from "@components/Reveal.astro";
import SectionHeading from "@components/SectionHeading.astro";

const img = (seed: string, w = 1600, h = 2000) =>
  `https://picsum.photos/seed/${seed}/${w}/${h}`;

const process = [
  {
    step: "01",
    title: "Source",
    text: "We buy from farms we can name and trust, in season, at a price that respects the work.",
  },
  {
    step: "02",
    title: "Roast",
    text: "Small batches, profiled by hand. We chase sweetness and clarity, not darkness for its own sake.",
  },
  {
    step: "03",
    title: "Brew",
    text: "Dialled in daily. The same bean tastes different with the weather, so we taste it every morning.",
  },
  {
    step: "04",
    title: "Serve",
    text: "In a real cup, at a real table, with time to drink it. That last step is the whole point.",
  },
];
---

<BaseLayout
  title="Coffee"
  description="Our coffee philosophy: patient sourcing, small-batch roasting, and a brew tuned by hand every morning at Mazi."
  path="/coffee"
  image="/og-coffee.jpg"
>
  <SmoothScroll />
  <Grain />
  <Nav />

  <main>
    <PhotoBand
      image={img("mazi-coffee-hero", 2000, 2400)}
      alt="A close pour of espresso into a white cup, crema catching the light."
      title="Coffee"
      eyebrow="Single origin, small batch"
      align="center"
      size="full"
    />

    <section class="philosophy">
      <div class="philosophy__inner reading-column">
        <Reveal>
          <p class="philosophy__lead display-lg">
            We treat the bean like a story worth telling slowly.
          </p>
        </Reveal>
        <Reveal>
          <p class="philosophy__body">
            Coffee is the most drunk thing in the world and often the least considered.
            At Mazi we slow it down. Every origin is tasted blind before it earns a
            place on the menu. Every roast is logged. Every cup is pulled by someone
            who cares whether you come back.
          </p>
        </Reveal>
        <Reveal>
          <p class="philosophy__body">
            We are not chasing the loudest, most acidic cup on the block. We are
            chasing the one you finish without checking your phone, then order again.
          </p>
        </Reveal>
      </div>
    </section>

    <section class="process">
      <div class="process__inner reading-column">
        <SectionHeading title="From cherry to cup" />
        <ol class="process__list">
          {
            process.map((p) => (
              <Reveal as="li" class="process__item" data-stagger>
                <span class="process__step micro-cap">{p.step}</span>
                <div class="process__text">
                  <h2 class="process__title display-lg">{p.title}</h2>
                  <p class="process__desc">{p.text}</p>
                </div>
              </Reveal>
            ))
          }
        </ol>
      </div>
    </section>

    <PhotoBand
      image={img("mazi-coffee-roaster", 2000, 1600)}
      alt="A small batch of roasted beans cooling in a tray."
      eyebrow="On the bar"
      title="Ask for the rotation"
      body="Our single origin changes through the year. The barista will tell you what is pouring today."
      cta={{ label: "See the menu", href: "/menu" }}
      align="end"
      size="tall"
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  .philosophy {
    padding-block: clamp(4rem, 12vw, 8rem);
  }
  .philosophy__inner {
    max-width: 760px;
  }
  .philosophy__lead {
    margin: 0 0 2rem;
    line-height: 1.25;
    text-wrap: balance;
  }
  .philosophy__body {
    margin: 0 0 1.5rem;
    color: var(--color-on-primary-mute);
    font-size: var(--text-body-lg);
    line-height: 1.8;
    max-width: 62ch;
  }
  .process {
    padding-block: clamp(4rem, 12vw, 8rem);
    background: var(--color-canvas-night-soft);
  }
  .process__list {
    list-style: none;
    margin: 3rem 0 0;
    padding: 0;
  }
  .process__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 1.5rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-hairline-dark);
  }
  .process__item:last-child {
    border-bottom: 1px solid var(--color-hairline-dark);
  }
  .process__step {
    color: var(--color-on-primary-mute);
    opacity: 0.6;
    padding-top: 0.5rem;
  }
  .process__title {
    margin: 0;
    font-size: clamp(24px, 4vw, 38px);
  }
  .process__desc {
    margin: 0.5rem 0 0;
    color: var(--color-on-primary-mute);
    max-width: 54ch;
    line-height: 1.7;
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce && window.maziStagger) window.maziStagger("[data-stagger]");
</script>