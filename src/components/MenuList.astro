---
import { menu } from "@data/menu";
import type { MenuSection } from "@data/menu";

export interface Props {
  sections?: MenuSection[];
  /** Limit to a subset of section ids (e.g. on the homepage). */
  only?: string[];
}
const { sections = menu, only } = Astro.props;
const visible = only ? sections.filter((s) => only.includes(s.id)) : sections;
---

<div class="menu">
  {
    visible.map((section) => (
      <section class="menu__section" id={section.id} aria-labelledby={`${section.id}-title`}>
        <div class="menu__head reading-column">
          <h2 class="menu__title display-lg" id={`${section.id}-title`}>
            {section.title}
          </h2>
          <p class="menu__blurb">{section.blurb}</p>
        </div>
        <ul class="menu__list reading-column">
          {section.items.map((item) => (
            <li class="menu__item">
              <div class="menu__item-text">
                <div class="menu__item-name">
                  <span>{item.name}</span>
                  {item.note && <span class="menu__note micro-cap">{item.note}</span>}
                </div>
                <p class="menu__desc">{item.description}</p>
              </div>
              <span class="menu__price">{item.price}</span>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</div>

<style>
  .menu {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 8vw, 6rem);
  }
  .menu__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 2rem;
    margin-bottom: 2rem;
  }
  .menu__title {
    margin: 0;
  }
  .menu__blurb {
    margin: 0;
    color: var(--color-on-primary-mute);
    opacity: 0.75;
    max-width: 36ch;
  }
  .menu__list {
    list-style: none;
    margin: 0;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }
  .menu__item {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-hairline-dark);
  }
  .menu__item:last-child {
    border-bottom: 1px solid var(--color-hairline-dark);
  }
  .menu__item-text {
    max-width: 60ch;
  }
  .menu__item-name {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.96px;
    font-size: clamp(18px, 2.4vw, 22px);
    font-weight: 700;
  }
  .menu__note {
    color: var(--color-on-primary-mute);
    opacity: 0.7;
  }
  .menu__desc {
    margin: 0.5rem 0 0;
    color: var(--color-on-primary-mute);
    line-height: 1.6;
  }
  .menu__price {
    font-family: var(--font-display);
    letter-spacing: 0.96px;
    font-size: clamp(16px, 2vw, 19px);
    white-space: nowrap;
    padding-top: 0.15rem;
  }
</style>