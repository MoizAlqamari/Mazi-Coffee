---
// Lenis smooth scrolling. Calm, cinematic. Respects reduced motion.
// Loaded once at the top of the page; no UI of its own.
---
<script>
  import Lenis from "lenis";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce) {
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // Pause Lenis when the mobile menu is open
    document.addEventListener("mazi:menu", (e) => {
      const open = (e as CustomEvent).detail === true;
      open ? lenis.stop() : lenis.start();
    });
  }
</script>