---
import "../styles/global.css";
import { site } from "@data/site";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Path of the current page, used for canonical + og:url. */
  path?: string;
  /** "website" for listing pages, "article" for story/editorial pages. */
  type?: "website" | "article";
}

const {
  title,
  description = site.description,
  image = "/og-default.jpg",
  path = "/",
  type = "website",
} = Astro.props;

const canonical = new URL(path, site.url).toString();
const ogImage = new URL(image, site.url).toString();
const pageTitle = title === site.name ? title : `${title} — ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_PK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: LocalBusiness / CafeOrCoffeeShop -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["CafeOrCoffeeShop", "LocalBusiness", "Restaurant"],
      name: site.name,
      description: site.description,
      url: site.url,
      telephone: site.phone,
      email: site.email,
      address: {
        "@type": "PostalAddress",
        streetAddress: site.address.street,
        addressLocality: site.address.city,
        addressRegion: site.address.region,
        postalCode: site.address.postalCode,
        addressCountry: site.address.country,
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: site.geo.lat,
        longitude: site.geo.lng,
      },
      servesCuisine: ["Coffee", "Desserts"],
      priceRange: "$$",
      openingHoursSpecification: site.hours.map((h) => ({
        "@type": "OpeningHoursSpecification",
        dayOfWeek: h.days,
        opens: h.time.split(" to ")[0],
        closes: h.time.split(" to ")[1],
      })),
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>